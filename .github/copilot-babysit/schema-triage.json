{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BabysitTriage",
  "type": "object",
  "required": ["decisions", "summary"],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "threadId",
          "category",
          "severity",
          "validConcern",
          "recommendation",
          "shouldTriggerFixLoop"
        ],
        "additionalProperties": false,
        "properties": {
          "threadId": { "type": "string", "minLength": 1 },
          "path": { "type": ["string", "null"] },
          "category": {
            "type": "string",
            "enum": [
              "Security",
              "Correctness",
              "Performance",
              "Test Coverage",
              "Code Cleanliness",
              "Readability",
              "Dependency",
              "Style/Pedantic"
            ]
          },
          "severity": { "type": "integer", "minimum": 1, "maximum": 5 },
          "validConcern": {
            "type": "string",
            "enum": ["Yes", "No", "Debatable"]
          },
          "recommendation": {
            "type": "string",
            "enum": ["Address", "Ignore", "Defer", "Discuss with team"]
          },
          "shouldTriggerFixLoop": { "type": "boolean" },
          "rationale": { "type": ["string", "null"], "maxLength": 240 },
          "duplicateGroup": { "type": ["string", "null"] }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["totalThreads", "byRecommendation"],
      "additionalProperties": false,
      "properties": {
        "totalThreads": { "type": "integer", "minimum": 0 },
        "byRecommendation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "Address": { "type": "integer", "minimum": 0 },
            "Ignore": { "type": "integer", "minimum": 0 },
            "Defer": { "type": "integer", "minimum": 0 },
            "Discuss with team": { "type": "integer", "minimum": 0 }
          }
        },
        "rootIssues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["group", "instances", "summary"],
            "additionalProperties": false,
            "properties": {
              "group": { "type": "string" },
              "instances": { "type": "integer", "minimum": 1 },
              "summary": { "type": "string", "maxLength": 240 }
            }
          }
        }
      }
    }
  }
}
