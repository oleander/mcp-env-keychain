{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CopilotBabysitState",
  "type": "object",
  "required": [
    "schemaVersion",
    "controllerVersion",
    "headSha",
    "iteration",
    "session"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "controllerVersion": { "type": "string" },
    "headSha": { "type": "string", "minLength": 7 },
    "lastEvent": { "type": ["string", "null"] },
    "lastEventAt": { "type": ["string", "null"] },
    "lastAction": { "type": ["string", "null"] },
    "lastActionAt": { "type": ["string", "null"] },
    "cooldownUntil": { "type": ["string", "null"] },
    "iteration": {
      "type": "object",
      "required": [
        "headSha",
        "copilotIteration",
        "reviewRequestCount",
        "fixRequestCount",
        "exhausted",
        "thresholdSeverity"
      ],
      "additionalProperties": false,
      "properties": {
        "headSha": { "type": "string", "minLength": 7 },
        "copilotIteration": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99
        },
        "reviewRequestCount": { "type": "integer", "minimum": 0 },
        "fixRequestCount": { "type": "integer", "minimum": 0 },
        "exhausted": { "type": "boolean" },
        "exhaustedReason": { "type": ["string", "null"] },
        "thresholdSeverity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "session": {
      "type": "object",
      "required": [
        "totalCopilotIterations",
        "totalReviewRequests",
        "totalFixRequests"
      ],
      "additionalProperties": false,
      "properties": {
        "totalCopilotIterations": { "type": "integer", "minimum": 0 },
        "totalReviewRequests": { "type": "integer", "minimum": 0 },
        "totalFixRequests": { "type": "integer", "minimum": 0 }
      }
    },
    "pendingRunId": { "type": ["string", "integer", "null"] },
    "pausedBy": { "type": ["string", "null"] },
    "humanEscalation": {
      "type": ["object", "null"],
      "required": ["reason", "since"],
      "additionalProperties": false,
      "properties": {
        "reason": { "type": "string" },
        "since": { "type": "string" }
      }
    },
    "triage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "byThread": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "headSha",
              "category",
              "severity",
              "validConcern",
              "recommendation",
              "shouldTriggerFixLoop",
              "decidedAt"
            ],
            "properties": {
              "headSha": { "type": "string", "minLength": 7 },
              "category": {
                "type": "string",
                "enum": [
                  "Security",
                  "Correctness",
                  "Performance",
                  "Test Coverage",
                  "Code Cleanliness",
                  "Readability",
                  "Dependency",
                  "Style/Pedantic"
                ]
              },
              "severity": { "type": "integer", "minimum": 1, "maximum": 5 },
              "validConcern": {
                "type": "string",
                "enum": ["Yes", "No", "Debatable"]
              },
              "recommendation": {
                "type": "string",
                "enum": ["Address", "Ignore", "Defer", "Discuss with team"]
              },
              "shouldTriggerFixLoop": { "type": "boolean" },
              "rationale": { "type": ["string", "null"] },
              "duplicateGroup": { "type": ["string", "null"] },
              "decidedAt": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
