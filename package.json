{
  "name": "k-mcp",
  "version": "0.2.0",
  "description": "MCP server for storing and using env secrets in the macOS Keychain (TypeScript on Bun)",
  "type": "module",
  "bin": {
    "k-mcp": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "compile": "bun build src/index.ts --compile --outfile dist/k-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
