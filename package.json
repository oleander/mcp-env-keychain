{
  "name": "@oleander/mcp-env-keychain",
  "version": "0.2.2",
  "description": "MCP server for storing and using env secrets in the macOS Keychain (TypeScript on Bun)",
  "type": "module",
  "bin": {
    "mcp-env-keychain": "./src/index.ts",
    "k-mcp": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "compile": "bun build --compile src/index.ts --outfile dist/mcp-env-keychain"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
